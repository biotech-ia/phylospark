# Copy this content into the GitHub secret PROD_ENV_FILE.

POSTGRES_USER=phylospark
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=phylospark

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-strong-password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=phylospark

AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://phylospark:replace-with-strong-password@postgres:5432/phylospark
AIRFLOW__CORE__FERNET_KEY=replace-with-generated-fernet-key
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=replace-with-long-random-secret
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=replace-with-strong-password

DATABASE_URL=postgresql://phylospark:replace-with-strong-password@postgres:5432/phylospark

NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

DOMAIN=automation.com.mx
ACME_EMAIL=your-email@example.com
DOCKERHUB_NAMESPACE=your-dockerhub-user
IMAGE_TAG=latest