{
  email andres@automation.com.mx
}

phylo.automation.com.mx {
  encode zstd gzip

  handle /api/* {
    reverse_proxy api:8000
  }

  handle /ws/* {
    reverse_proxy api:8000
  }

  handle /spark/* {
    uri strip_prefix /spark
    reverse_proxy api:4040
  }

  handle {
    reverse_proxy frontend:3000
  }
}

api.phylo.automation.com.mx {
  encode zstd gzip
  reverse_proxy api:8000
}

airflow.phylo.automation.com.mx {
  encode zstd gzip
  reverse_proxy airflow-webserver:8080
}

minio.phylo.automation.com.mx {
  encode zstd gzip
  reverse_proxy minio:9001
}

s3.phylo.automation.com.mx {
  encode zstd gzip
  reverse_proxy minio:9000
}
