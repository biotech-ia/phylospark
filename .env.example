# PhyloSpark Environment Variables
# Copy to .env and fill in values

# === AWS ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2

# === PostgreSQL ===
POSTGRES_USER=phylospark
POSTGRES_PASSWORD=phylospark_dev_2024
POSTGRES_DB=phylospark
POSTGRES_PORT=5432

# === MinIO ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_CONSOLE_PORT=9001

# === Airflow ===
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://phylospark:phylospark_dev_2024@postgres:5432/phylospark
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-production
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# === FastAPI ===
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql://phylospark:phylospark_dev_2024@postgres:5432/phylospark
MINIO_BUCKET=phylospark

# === NCBI ===
NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=

# === Domain (production) ===
DOMAIN=automation.com.mx
ELASTIC_IP=3.136.146.185
